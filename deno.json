{
  "tasks": {
    "build": "deno run -A build/esbuild-build.ts",
    "serve": "deno run --allow-all serve.ts"
  },
  "deploy": {
    "org": "ubiquity-dao",
    "install": "deno install",
    "build": "deno task build",
    "runtime": {
      "type": "static",
      "cwd": "./static",
      "spa": true
    }
  }
}
